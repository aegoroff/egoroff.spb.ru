{
  "name": "ui.egoroff.spb.ru",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit && node scripts/vue-tsc-ts6.cjs --noEmit",
    "typecheck:ts": "tsc --noEmit",
    "typecheck:vue": "node scripts/vue-tsc-ts6.cjs --noEmit",
    "build": "bun run typecheck && vite build && bun scripts/inject-askama-assets.ts",
    "devbuild": "vite build --mode development && bun scripts/inject-askama-assets.ts",
    "lint": "node --require ./scripts/eslint-ts6-alias.cjs ./node_modules/eslint/bin/eslint.js src/"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/vue-fontawesome": "^3.3.2",
    "@marcoschulte/vue3-progress": "^0.0.9",
    "axios": "^1.18.1",
    "bootstrap": "^5.3.8",
    "dayjs": "^1.11.21",
    "highlight.js": "^11.11.1",
    "highlightjs-zig": "^1.0.2",
    "mitt": "^3.0.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vue3-social-sharing": "^1.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/compiler-sfc": "^3.5.39",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "sass": "^1.101.0",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vue-tsc": "^3.3.7"
  }
}
